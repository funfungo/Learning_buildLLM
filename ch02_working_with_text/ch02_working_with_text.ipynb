            "权重矩阵 shape: torch.Size([6, 3])\n",
            "权重矩阵:\n",
            "tensor([[ 0.7494,  0.3546,  2.2243],\n",
            "        [ 1.3281,  0.6179,  0.3688],\n",
            "        [-2.3082, -1.0758,  0.1457],\n",
            "        [-0.5436, -0.3582, -1.0263],\n",
            "        [-0.1631, -0.5457, -0.2944],\n",
            "        [ 0.8362,  0.0211, -0.4070]])\n",
            "\n",
